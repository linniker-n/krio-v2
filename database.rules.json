{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "memberships": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        "$tenantId": {
          ".write": "auth != null && ((auth.uid == $uid && $tenantId == 'tenant_' + auth.uid && !data.exists() && newData.child('status').val() == 'active' && newData.child('role').val() == 'owner') || (root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin') && (!newData.exists() || (newData.child('status').val() == 'active' && (newData.child('role').val() == 'admin' || newData.child('role').val() == 'member' || newData.child('role').val() == 'client' || newData.child('role').val() == 'guest')))))"
        }
      }
    },
    "accessRequests": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || (data.child('tenantId').exists() && root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'admin')))",
        ".write": "auth != null && ((auth.uid == $uid && (!data.exists() || data.child('status').val() == 'pending') && newData.child('uid').val() == auth.uid && newData.child('status').val() == 'pending') || (data.child('tenantId').exists() && root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'admin')))",
        ".validate": "newData.hasChildren(['uid', 'email', 'agencyName', 'status', 'requestedAt'])"
      }
    },
    "tenantAccessRequests": {
      "$tenantId": {
        ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
        "$uid": {
          ".write": "auth != null && ((auth.uid == $uid && (!data.exists() || data.child('status').val() == 'pending') && newData.child('uid').val() == auth.uid && newData.child('tenantId').val() == $tenantId && newData.child('status').val() == 'pending') || (root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')))"
        }
      }
    },
    "tenantDomains": {
      "$domain": {
        ".read": "auth != null",
        "$tenantId": {
          ".write": "auth != null && (($tenantId == 'tenant_' + auth.uid && !data.exists() && newData.child('ownerUid').val() == auth.uid) || (root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')))"
        }
      }
    },
    "approvalPortals": {
      "$clientId": {
        ".read": true,
        ".write": "auth != null && ((newData.exists() && root.child('memberships').child(auth.uid).child(newData.child('tenantId').val()).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child(newData.child('tenantId').val()).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child(newData.child('tenantId').val()).child('role').val() == 'admin')) || (data.exists() && root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('status').val() == 'active' && (root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child(data.child('tenantId').val()).child('role').val() == 'admin')))",
        ".validate": "!newData.exists() || (newData.child('tenantId').isString() && newData.child('clientId').val() == $clientId)"
      }
    },
    "tenants": {
      "$tenantId": {
        ".read": false,
        ".write": "auth != null && $tenantId == 'tenant_' + auth.uid && !data.exists() && newData.child('meta').child('ownerUid').val() == auth.uid && newData.child('meta').child('status').val() == 'active'",
        "meta": {
          ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
          "name": {
            ".write": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner'"
          },
          "slug": {
            ".write": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner'"
          },
          "plan": {
            ".write": false
          },
          "licenseStatus": {
            ".write": false
          },
          "licenseType": {
            ".write": false
          },
          "billingStatus": {
            ".write": false
          },
          "trialEndsAt": {
            ".write": false
          },
          "status": {
            ".write": false
          },
          "ownerUid": {
            ".write": false
          },
          "createdAt": {
            ".write": false
          }
        },
        "billing": {
          ".read": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          ".write": false
        },
        "profiles": {
          ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
        },
        "tracker": {
          "weeks": {
            ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
            ".write": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'"
          },
          "events": {
            ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
            ".write": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'"
          }
        },
        "trash": {
          ".read": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          "$uid": {
            ".read": "auth != null && (auth.uid == $uid || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
            ".write": "auth != null && (auth.uid == $uid || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
          }
        },
        "approval": {
          ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          "clients": {
            "$clientId": {
              ".read": "(auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active') || root.child('approvalPortals').child($clientId).child('tenantId').val() == $tenantId",
              ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
              "groups": {
                "$groupId": {
                  "cards": {
                    "$cardId": {
                      ".write": "(auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')) || (auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active' && data.child('status').val() == 'internalRejected' && newData.child('status').val() == 'prov') || (root.child('approvalPortals').child($clientId).child('tenantId').val() == $tenantId && data.child('status').val() == 'clientReview' && (newData.child('status').val() == 'scheduled' || newData.child('status').val() == 'internalRejected'))",
                      ".validate": "(auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')) || (newData.exists() && data.exists() && newData.child('id').val() == data.child('id').val() && newData.child('title').val() == data.child('title').val() && (!data.child('caption').exists() || newData.child('caption').val() == data.child('caption').val()) && (!data.child('imageUrl').exists() || newData.child('imageUrl').val() == data.child('imageUrl').val()) && (!data.child('driveUrl').exists() || newData.child('driveUrl').val() == data.child('driveUrl').val()) && (!data.child('createdAt').exists() || newData.child('createdAt').val() == data.child('createdAt').val()))"
                    }
                  }
                }
              }
            }
          }
        },
        "planning": {
          ".read": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
        },
        "clients": {
          ".read": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
        },
        "brand": {
          ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
        },
        "settings": {
          ".read": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')",
          ".write": "auth != null && (root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'owner' || root.child('memberships').child(auth.uid).child($tenantId).child('role').val() == 'admin')"
        },
        "updatedAt": {
          ".read": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'",
          ".write": "auth != null && root.child('memberships').child(auth.uid).child($tenantId).child('status').val() == 'active'"
        }
      }
    }
  }
}
