{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      ".git",
      ".git/**",
      ".claude",
      ".claude/**",
      ".agents",
      ".agents/**",
      ".firebase",
      ".firebase/**",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "server.err.log",
      "server.out.log",
      "*.log",
      "skills-lock.json",
      "scripts/*.ps1",
      "scripts/smoke-test.mjs",
      "functions/**",
      "PRODUCTIZATION.md",
      "GO_LIVE.md",
      "firebase-rules.example.json",
      "database.rules.json",
      "KRIO V2.zip",
      "popp-tracker-firebase.html",
      "APROVAÇÃO.html",
      "Operação.html"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/approval/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/app",
        "destination": "/app/index.html"
      },
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/login",
        "destination": "/index.html"
      }
    ]
  }
}
